# dependencies
node_modules/
.pnp.*
.yarn/*

# build output
dist/
build/
.next/
out/
*.tsbuildinfo

# turbo
.turbo/

# emitted TypeScript output — all source is .ts/.tsx; compiled files are never
# authored and must never be committed (can leak into src/ if tsc is told to emit)
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map
packages/*/__tests__/**/*.js
apps/*/src/**/*.js
apps/*/src/**/*.d.ts

# test / coverage
coverage/
playwright-report/
test-results/

# env — NEVER commit secrets (see .env.example for the template)
.env
.env.local
.env.*.local

# editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.log
npm-debug.log*
pnpm-debug.log*
