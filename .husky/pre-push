#!/usr/bin/env sh
# pre-push — run the same checks CI runs, before anything leaves your machine.
# Aborts the push if typecheck or tests fail. Runs on every push (any branch),
# so your PR is green before CI even starts. Mirrors .github/workflows/ci.yml.
#
# Bypass only when you truly must:  git push --no-verify
# Add Homebrew and local binary paths to PATH for GUI Git clients
export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

# Load NVM (Node Version Manager) if present
export NVM_DIR="$HOME/.nvm"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  . "$NVM_DIR/nvm.sh"
  if [ -f ".nvmrc" ]; then
    NVMRC_VER=$(cat .nvmrc)
    if nvm ls "$NVMRC_VER" >/dev/null 2>&1; then
      nvm use --silent "$NVMRC_VER"
    elif nvm ls "v20.20.0" >/dev/null 2>&1; then
      nvm use --silent "v20.20.0"
    else
      nvm use --silent default
    fi
  else
    nvm use --silent default
  fi
fi

echo "🔎 pre-push: running CI checks (typecheck + tests)…"

if ! pnpm typecheck; then
  echo "❌ pre-push: typecheck failed — push aborted."
  echo "   Fix the errors above, or bypass with:  git push --no-verify"
  exit 1
fi

if ! pnpm test; then
  echo "❌ pre-push: tests failed — push aborted."
  echo "   Fix the failures above, or bypass with:  git push --no-verify"
  exit 1
fi

echo "✅ pre-push: all checks passed — pushing."
