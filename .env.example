# ─────────────────────────────────────────────────────────────
# TravelMate environment template.
# Copy to .env.local and fill in. NEVER commit .env.local (gitignored).
# Skeleton phase: nothing here is wired yet — these document intent.
# ─────────────────────────────────────────────────────────────

# --- LLM (packages/llm) -------------------------------------------------
# Provider-agnostic. Default provider is Anthropic; Gemini is wired as the
# cheap high-volume fallback. See projectStructure.md §7.
LLM_PROVIDER=mock                 # mock | anthropic | gemini
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Fetchers (packages/fetchers) --------------------------------------
# Phase 1 is scraping; APIs slot in later behind the same interface.
FETCHER_MODE=mock                 # mock | scraper | api
SCRAPER_PROXY_URL=                # optional, for the scraper phase
# Later (API phase) — affiliate / provider credentials:
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
# SKYSCANNER_AFFILIATE_ID=
# BOOKING_AFFILIATE_ID=

# --- Database (packages/database) --------------------------------------
DATABASE_MODE=memory              # memory | redis+postgres
REDIS_URL=                        # cache store (freshness-scored)
POSTGRES_URL=                     # persistence (users, saved trips, trip-mode)
DEBUG_FRESHNESS_HOURS=24          # single dev freshness knob (projectStructure.md §5)

# --- API host (apps/api) -----------------------------------------------
API_PORT=8080

# --- Web (apps/web) ----------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
